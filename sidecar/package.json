    "@types/node": "^20.0.0",
    "@types/node-forge": "^1.3.14",
    "@types/xml2js": "^0.4.11",
    "@vercel/ncc": "^0.38.4",
    "esbuild": "^0.27.3",
    "fs-extra": "^11.3.3",
